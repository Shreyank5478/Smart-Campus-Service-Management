rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    // Look up the user's role from their Firestore doc (keyed by UID)
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return getUserRole() == 'Admin';
    }

    function isStaff() {
      return getUserRole() in ['Staff', 'Technician'];
    }

    // ===================================
    // USERS COLLECTION
    // ===================================
    match /users/{uid} {
      // Any authenticated user can read user profiles (needed for staff assignment dropdown)
      allow read: if isAuth();

      // Users can create their own document (doc ID must match their auth UID)
      allow create: if isAuth() &&
                       request.auth.uid == uid &&
                       validateUserCreate();

      // Users can update their own non-critical fields; only Admins can grant Admin role
      allow update: if isAuth() &&
                       (request.auth.uid == uid || isAdmin()) &&
                       validateUserUpdate();

      // Only admins can delete user documents
      allow delete: if isAdmin();

      function validateUserCreate() {
        let d = request.resource.data;
        return d.keys().hasAll(['email', 'name', 'role']) &&
               d.email is string && d.email.size() > 0 &&
               d.name is string && d.name.size() >= 2 && d.name.size() <= 100 &&
               d.role in ['Student', 'Staff', 'Technician', 'Admin'];
        // Note: Admin role IS allowed here so the first Admin can be created via signup.
        // In production, remove 'Admin' from this list after the first admin is created.
      }

      function validateUserUpdate() {
        let d = request.resource.data;
        let old = resource.data;
        return (!('email' in d) || d.email == old.email) &&
               (!('name' in d) || (d.name is string && d.name.size() >= 2 && d.name.size() <= 100)) &&
               (!('role' in d) || (
                 d.role in ['Student', 'Staff', 'Technician', 'Admin'] &&
                 (d.role != 'Admin' || isAdmin())
               )) &&
               (!('password' in d));
      }
    }

    // ===================================
    // SERVICE REQUESTS COLLECTION
    // ===================================
    match /service_requests/{requestId} {
      // Students read their own; staff/admin read all
      allow read: if isAuth() &&
                     (resource.data.studentId == request.auth.uid ||
                      isStaff() || isAdmin());

      // Students can create requests for themselves
      allow create: if isAuth() &&
                       request.resource.data.studentId == request.auth.uid &&
                       validateServiceRequestCreate();

      // Student (owner), assigned staff, or admin can update
      allow update: if isAuth() &&
                       (resource.data.studentId == request.auth.uid ||
                        isStaff() || isAdmin()) &&
                       validateServiceRequestUpdate();

      // Only admins can delete
      allow delete: if isAdmin();

      function validateServiceRequestCreate() {
        let d = request.resource.data;
        return d.keys().hasAll(['description', 'location', 'category', 'studentId']) &&
               d.description is string && d.description.size() >= 5 && d.description.size() <= 5000 &&
               d.location is string && d.location.size() >= 3 && d.location.size() <= 200 &&
               d.category in ['Electrical', 'Internet', 'Hostel', 'Classroom', 'Plumbing', 'Other'] &&
               d.status == 'Pending';
      }

      function validateServiceRequestUpdate() {
        let d = request.resource.data;
        let old = resource.data;
        let validStatuses = ['Pending', 'In Progress', 'Resolved'];
        return (!('status' in d) || d.status in validStatuses) &&
               (!('description' in d) || (d.description is string && d.description.size() >= 5 && d.description.size() <= 5000)) &&
               (!('location' in d) || (d.location is string && d.location.size() >= 3 && d.location.size() <= 200)) &&
               (!('category' in d) || d.category in ['Electrical', 'Internet', 'Hostel', 'Classroom', 'Plumbing', 'Other']);
      }

      // Feedback subcollection
      match /feedback/{ratingId} {
        allow read: if isAuth();
        allow create: if isAuth() &&
                         request.auth.uid == get(/databases/$(database)/documents/service_requests/$(requestId)).data.studentId;
        allow update, delete: if false;
      }
    }

    // Default deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
