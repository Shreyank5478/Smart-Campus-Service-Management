# Backend .gitignore

# Environment variables (secrets)
.env
.env.local
.env.*.local

# Node modules
node_modules/

# Firebase service account (NEVER commit this!)
serviceAccountKey.json

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS files
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo

# Build outputs
dist/
build/

# Temporary files
tmp/
temp/

# Package manager lock (optional)
# Uncomment if working in team:
# package-lock.json
# yarn.lock
